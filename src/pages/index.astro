---
import { getCollection } from 'astro:content';
import { Image } from "astro:assets";
import Base from '../layouts/Base.astro';
import '../styles/index.css';
import '../styles/global.css';


const products = await getCollection('products');
const allTags  = ['all', ...new Set(products.flatMap(p => p.data.tags))];
// console.log(products);
---

<Base title="Pheel Downloads">

<div class="bg-grid"> </div>
  <div class="page-wrap">

    <header class="site-header">
      <div class="header-left">
        <p class="site-eyebrow">Free resources</p>
        <h1 class="site-title">FREEBIES <br /> Downloads</h1>
      </div>
      <div class="header-right">
        <p class="site-note">
          All files are <strong>Free</strong>. No account needed.
        </p>
      </div>
    </header>

    <div class="filters">
      <span class="filters-label">Filter</span>
      {allTags.map(tag => (
        <button
          class={`filter-btn${tag === 'all' ? ' active' : ''}`}
          data-tag={tag}
        >
          {tag}
        </button>
      ))}
    </div>

    <div class="product-grid" id="product-grid">
      {products.map(product => (
        <a
          class="card"
          href={`/product/${product.id}`}
          data-tags={product.data.tags.join(',')}
          data-color={product.data.color}
        >
        
          <div class="card-image-container" data-color={product.data.color}>
            {product.data.image
              ? 
                <div class="image-container">
                  <Image src={product.data.image} alt={product.data.name} class="main-image" width={800} height={600}/>
                  <div class="image-blank_2">
                    <img src={product.data.imagetwo} alt="" loading="lazy"/> 
                    {/* <Image src={product.data.imagetwo} alt="..." width={800} height={600}/>  */}
                  </div>
                  <div class="div-blank_1">
                    <img src={product.data.imagethree} alt="" loading="lazy"/> 
                    {/* <Image src={product.data.imagethree} alt="..." width={800} height={600}/>  */}
                  </div>

                  <div class="icon1">
                    <img src={product.data.icons[0]} alt="" loading="lazy">
                    {/* <Image src={product.data.icons[0]} alt="..." width={800} height={600}/> */}
                  </div>
                </div>
              : 
                <div class="card-image-placeholder">↓</div>
            }
          </div>
        
          <div class="card-body">
            <div class="card-tags">
              {product.data.tags.map(tag => (
                <span class="tag">{tag}</span>
              ))}
            </div>
            <div class="card-name">{product.data.name}</div>
            <p class="card-tagline">{product.data.tagline}</p>
          </div>

          <div class="card-footer">
            <span class="card-file-label">{product.data.fileLabel}</span>
            <span class="card-cta">View <span>→</span></span>
          </div>

        </a>
      ))}
    </div>

    <footer class="site-footer">
      <span id="product-count"></span>
    </footer>

  </div>

  <script src="../scripts/filter.js"></script>

</Base>
