---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import '../../styles/product.css';
import '../../styles/global.css';
import { render } from 'astro:content';


export async function getStaticPaths() {
  const products = await getCollection('products');
  return products.map(product => ({
    params: { id: product.id },
    props:  { product },
  }));
}

const { product } = Astro.props;
const { data }    = product;
const { Content } = await render(product);

const allImages = [data.image, ...(data.images ?? [])].filter(Boolean) as string[];
---

<Base title={`${data.name} | Downloads`}>

  <div class="page-wrap">

    <nav class="breadcrumb">
      <a href="/">Downloads</a>
      <span class="breadcrumb-sep">›</span>
      <span class="breadcrumb-current">{data.name}</span>
    </nav>

    <div class="product-layout">

      <!-- Left: gallery -->
      <div class="product-gallery">
        <div class="gallery-main" data-color={data.color}>
          {allImages.length > 0
            ? <img id="gallery-main-img" src={allImages[0]} alt={data.name} />
            : <div class="gallery-main-placeholder">↓</div>
          }
        </div>

        {allImages.length > 1 && (
          <div class="gallery-thumbs">
            {allImages.map((src, i) => (
              <div
                class={`gallery-thumb${i === 0 ? ' active' : ''}`}
                data-src={src}
              >
                <img src={src} alt="" loading="lazy" />
              </div>
            ))}
          </div>
        )}
      </div>

      <!-- Right: info -->
      <div class="product-info">

        <div class="product-tags">
          {data.tags.map(tag => <span class="tag">{tag}</span>)}
        </div>

        <h1 class="product-name">{data.name}</h1>
        <p class="product-tagline">{data.tagline}</p>

        <div class="download-card">
          <p class="download-card-label">Free download</p>
          <p class="download-card-filename">{data.fileLabel}</p>
          <a class="download-btn" href={data.file} download>
            <span class="download-btn-icon">↓</span>
            Download for free
          </a>
        </div>

        <div class="product-description">
          <p class="description-label">About this product</p>
          <div class="prose">
            <Content />
          </div>
        </div>

        {data.date && (
          <p class="product-date">Released {data.date}</p>
        )}

      </div>
    </div>

  </div>

  <script src="../../scripts/gallery.js"></script>

</Base>
